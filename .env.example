# Copy to ~/.hermes/.env or export in your shell

# ── Mode ──────────────────────────────────────────────────────────
# MOA_MODE=local   # default — local Ollama, no auth needed
# MOA_MODE=cloud   # Ollama Cloud — requires API key below

# ── Local Ollama ──────────────────────────────────────────────────
# OLLAMA_URL=http://127.0.0.1:11434/v1/chat/completions
# OLLAMA_TAGS_URL=http://127.0.0.1:11434/api/tags

# ── Ollama Cloud ──────────────────────────────────────────────────
# OLLAMA_BASE_URL=https://ollama.com/v1
# OLLAMA_API_KEY=*** # Get from https://ollama.com/settings/api

# ── Token budgets ──────────────────────────────────────────────────
# MOA_REF_MAX_TOKENS=8000
# MOA_AGG_MAX_TOKENS=16000

# ── Concurrency ───────────────────────────────────────────────────
# MOA_MAX_CONCURRENCY=4
